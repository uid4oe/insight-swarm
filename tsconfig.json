{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"outDir": "dist",
		"rootDir": ".",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"declaration": true
	},
	"include": ["backend/**/*", "shared/**/*"]
}
