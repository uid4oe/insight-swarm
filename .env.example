# ── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here

# ── Local dev (used by pnpm dev, not by docker compose) ──────────────────────
DATABASE_URL=postgresql://mts:mts@localhost:5432/insight_swarm
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Docker compose passwords (used by docker compose only) ───────────────────
POSTGRES_PASSWORD=mts
RABBITMQ_PASSWORD=guest

# ── Optional: LLM ────────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.0-flash
# LLM_RATE_LIMIT_RPM=60
# ADK_RUN_TIMEOUT_MS=180000
# ADK_DEBUG=false

# ── Optional: Swarm tuning ───────────────────────────────────────────────────
# MAX_ROUNDS=4
# MAX_FINDINGS_PER_ROUND=5
# MAX_REACTIONS_PER_ROUND=8
# MAX_TURNS_PER_ROUND=15
# THESIS_THRESHOLD=3
# MAX_THESES=8

# ── Optional: Google Search ──────────────────────────────────────────────────
# GOOGLE_SEARCH_ENABLED=true
# GOOGLE_SEARCH_MAX_PER_ROUND=3
